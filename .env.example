# ===== Database =====
DATABASE_URL=postgresql://radar:radar@localhost:5432/event_radar

# ===== API =====
PORT=3001
API_KEY=your-api-key-here
# AUTH_REQUIRED defaults to true in production (set in index.ts).
# Set to false explicitly for local development without authentication.
AUTH_REQUIRED=false
JWT_SECRET=your-jwt-secret-here
CORS_ORIGIN=http://localhost:5173
# Content-Security-Policy headers (default: true). Set to false to disable.
CSP_ENABLED=true

# ===== Scanner Toggles =====
# RSS-based scanners (free, enabled by default)
BREAKING_NEWS_ENABLED=true
FEDWATCH_ENABLED=false
WHITEHOUSE_ENABLED=true
FDA_ENABLED=false
DOJ_ENABLED=false
CONGRESS_ENABLED=false
ECON_CALENDAR_ENABLED=true
SHORT_INTEREST_ENABLED=false

# Social scanners (free RSS-based)
REDDIT_ENABLED=true
STOCKTWITS_ENABLED=true

# Options scanner
UNUSUAL_OPTIONS_ENABLED=false

# Analyst/Earnings/WARN
ANALYST_ENABLED=false
EARNINGS_ENABLED=false
WARN_ENABLED=true

# Scraping-based scanners (need Playwright, disabled for now)
TRUTH_SOCIAL_ENABLED=false
X_SCANNER_ENABLED=false
TWITTER_API_KEY=your_twitterapi_io_key
X_SCANNER_ACCOUNTS=realDonaldTrump,elonmusk,DeItaone,unusual_whales,zaborsky,FirstSquawk

# ===== Delivery =====
# Optional Redis-backed infra
REDIS_URL=redis://localhost:6379
DEDUP_REDIS_ENABLED=false
DEDUP_REDIS_URL=redis://localhost:6379

# Discord delivery
DISCORD_WEBHOOK_URL=

# ===== LLM (optional) =====
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_ENRICHMENT_ENABLED=false
# LLM Gatekeeper (quality filter for secondary sources)
LLM_GATEKEEPER_ENABLED=false
LLM_GATEKEEPER_API_KEY=your-gatekeeper-api-key-here
LLM_GATEKEEPER_MODEL=gpt-4o-mini
ALERT_FILTER_ENABLED=true

# ===== Phase 1+ Scanners =====
FEDERAL_REGISTER_ENABLED=true
SEC_EDGAR_ENABLED=true
NEWSWIRE_ENABLED=true

# Phase 3 scanners
HALT_SCANNER_ENABLED=true
IR_MONITOR_ENABLED=true
DILUTION_SCANNER_ENABLED=true
DELIVERY_GATE_MODE=enforce
