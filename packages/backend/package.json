    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
