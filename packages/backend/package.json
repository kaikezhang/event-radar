{
  "name": "@event-radar/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/config && cp src/config/*.json dist/config/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "golden-check": "tsx src/scripts/golden-drift-check.ts",
    "generate:vapid": "bash scripts/generate-vapid-keys.sh",
    "seed:tickers": "tsx src/scripts/seed-tickers.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@event-radar/delivery": "workspace:*",
    "@event-radar/shared": "workspace:*",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "cheerio": "1.0.0-rc.12",
    "crawlee": "^3.16.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.0",
    "jose": "^6.2.1",
    "openai": "^6.27.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.3",
    "resend": "^6.9.3",
    "yahoo-finance2": "^3.9.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.0.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
